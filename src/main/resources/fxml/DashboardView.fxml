<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<?import javafx.scene.canvas.Canvas?>
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.mst.matt.tradingplatformapp.controller.DashboardController"
      styleClass="scene-root" spacing="20">

    <!-- Top Stat Cards -->
    <HBox fx:id="statsSection" spacing="16">
        <VBox styleClass="stat-card stat-card-blue" HBox.hgrow="ALWAYS" spacing="6">
            <Label text="TOTAL P&amp;L" styleClass="label-muted"/>
            <!-- \$ = literal $ in FXML -->
            <Label fx:id="totalPnlLabel" text="\$0.00" styleClass="label-value"/>
            <Label fx:id="totalPnlPctLabel" text="0.00%" styleClass="label-subtitle"/>
        </VBox>

        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="6">
            <Label text="WIN RATE" styleClass="label-muted"/>
            <Label fx:id="winRateLabel" text="0%" styleClass="label-value"/>
            <Label fx:id="winLossLabel" text="0W / 0L" styleClass="label-subtitle"/>
        </VBox>

        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="6">
            <Label text="TOTAL TRADES" styleClass="label-muted"/>
            <Label fx:id="totalTradesLabel" text="0" styleClass="label-value"/>
            <Label fx:id="openTradesLabel" text="0 Open" styleClass="label-subtitle"/>
        </VBox>

        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="6">
            <Label text="BEST TRADE" styleClass="label-muted"/>
            <Label fx:id="bestTradeLabel" text="\$0.00" style="-fx-font-size:28px; -fx-font-weight:bold; -fx-text-fill:#3fb950;"/>
            <Label text="All time" styleClass="label-muted"/>
        </VBox>

        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="6">
            <Label text="WORST TRADE" styleClass="label-muted"/>
            <Label fx:id="worstTradeLabel" text="\$0.00" style="-fx-font-size:28px; -fx-font-weight:bold; -fx-text-fill:#f85149;"/>
            <Label text="All time" styleClass="label-muted"/>
        </VBox>

        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="6">
            <Label text="PROFIT FACTOR" styleClass="label-muted"/>
            <Label fx:id="profitFactorLabel" text="0.00" styleClass="label-value"/>
            <Label fx:id="avgWinLossLabel" text="Avg W/L: —" styleClass="label-subtitle"/>
        </VBox>
    </HBox>

    <!-- Middle: Equity Curve + Breakdown -->
    <HBox fx:id="middleSection" spacing="16" VBox.vgrow="ALWAYS">
        <VBox styleClass="card" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS" spacing="12">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <Label text="📈 Equity Curve" styleClass="label-title" style="-fx-font-size:14px;"/>
                <Pane HBox.hgrow="ALWAYS"/>
                <Button text="1W" styleClass="btn-secondary" style="-fx-padding:4 10;" onAction="#onFilter1W"/>
                <Button text="1M" styleClass="btn-secondary" style="-fx-padding:4 10;" onAction="#onFilter1M"/>
                <Button text="3M" styleClass="btn-secondary" style="-fx-padding:4 10;" onAction="#onFilter3M"/>
                <Button text="ALL" styleClass="btn-blue" style="-fx-padding:4 10;" onAction="#onFilterAll"/>
            </HBox>
            <Canvas
                    fx:id="equityCanvas"
                    width="700"
                    height="200"/>
        </VBox>

        <VBox styleClass="card" prefWidth="280" spacing="12">
            <Label text="🗂 Asset Breakdown" styleClass="label-title" style="-fx-font-size:14px;"/>
            <VBox fx:id="breakdownContainer" spacing="10"/>
        </VBox>
    </HBox>

    <!-- Recent Trades / Trade Journal -->
    <VBox fx:id="tradesSection" styleClass="card" VBox.vgrow="ALWAYS" spacing="12" minHeight="200">
        <HBox alignment="CENTER_LEFT" spacing="12">
            <Label fx:id="tradesSectionTitle" text="Recent Trades" styleClass="label-title" style="-fx-font-size:14px;"/>
            <Pane HBox.hgrow="ALWAYS"/>
            <Button text="+ New Trade" styleClass="btn-primary" onAction="#onNewTrade"/>
            <Button fx:id="viewAllBtn" text="View All" styleClass="btn-secondary" onAction="#onViewAll"/>
        </HBox>

        <!-- Tab pane: "My Trades" (always present) + dynamic broker import tabs -->
        <TabPane fx:id="tradesTabPane" VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE"
                 style="-fx-background-color:#161b22; -fx-tab-min-width:120px;">
            <tabs>
                <Tab fx:id="myTradesTab" text="📋 My Trades">
                    <!-- Wrap table in ScrollPane so it is always scrollable and fits window -->
                    <ScrollPane fitToWidth="true" fitToHeight="false"
                                hbarPolicy="AS_NEEDED" vbarPolicy="AS_NEEDED"
                                style="-fx-background-color:#161b22; -fx-background:#161b22;"
                                VBox.vgrow="ALWAYS">
                        <TableView fx:id="recentTradesTable"
                                   maxHeight="1.7976931348623157E308"
                                   style="-fx-background-color:#161b22; -fx-border-color:#30363d; -fx-border-width:1;">
                            <placeholder>
                                <Label text="📋 No trades yet — click '+ New Trade' to get started."
                                       style="-fx-text-fill:#8b949e; -fx-font-size:13px;"/>
                            </placeholder>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                            </columnResizePolicy>
                            <columns>
                                <TableColumn fx:id="colDate"    text="DATE"     minWidth="100" prefWidth="130"/>
                                <TableColumn fx:id="colSymbol"  text="SYMBOL"   minWidth="80"  prefWidth="100"/>
                                <TableColumn fx:id="colType"    text="TYPE"     minWidth="60"  prefWidth="70"/>
                                <TableColumn fx:id="colDir"     text="DIR"      minWidth="50"  prefWidth="60"/>
                                <TableColumn fx:id="colEntry"   text="ENTRY"    minWidth="80"  prefWidth="110"/>
                                <TableColumn fx:id="colExit"    text="EXIT"     minWidth="80"  prefWidth="110"/>
                                <TableColumn fx:id="colQty"     text="QTY"      minWidth="60"  prefWidth="90"/>
                                <TableColumn fx:id="colPnl"     text="P&amp;L $" minWidth="80" prefWidth="100"/>
                                <TableColumn fx:id="colPnlPct"  text="P&amp;L %" minWidth="70" prefWidth="90"/>
                                <TableColumn fx:id="colStatus"  text="STATUS"   minWidth="60"  prefWidth="80"/>
                                <TableColumn fx:id="colActions" text="ACTIONS"  minWidth="80"  prefWidth="100"/>
                            </columns>
                        </TableView>
                    </ScrollPane>
                </Tab>
                <!-- Dynamic broker tabs are added programmatically in DashboardController -->
            </tabs>
        </TabPane>
    </VBox>

</VBox>