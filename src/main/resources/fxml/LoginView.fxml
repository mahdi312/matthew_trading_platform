<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.mst.matt.tradingplatformapp.controller.LoginController"
           style="-fx-background-color:#0d1117;"
           prefWidth="420" prefHeight="520">

    <VBox alignment="CENTER" spacing="0" maxWidth="380" maxHeight="480"
          style="-fx-background-color:#161b22; -fx-border-color:#30363d; -fx-border-width:1;
                 -fx-background-radius:12; -fx-border-radius:12;"
          StackPane.alignment="CENTER">

        <padding>
            <Insets top="40" right="40" bottom="40" left="40"/>
        </padding>

        <!-- Logo / title -->
        <Label text="📈" style="-fx-font-size:48px;" alignment="CENTER"/>
        <Label text="Trading Platform" style="-fx-font-size:22px; -fx-font-weight:bold;
               -fx-text-fill:#e6edf3;" alignment="CENTER"/>
        <Label text="Sign in to your account"
               style="-fx-font-size:13px; -fx-text-fill:#8b949e;" alignment="CENTER"/>

        <VBox spacing="0">
            <padding><Insets top="28"/></padding>
        </VBox>

        <!-- Error label -->
        <Label fx:id="errorLabel" text="" wrapText="true"
               style="-fx-text-fill:#f85149; -fx-font-size:12px; -fx-padding:0 0 8 0;"
               alignment="CENTER" managed="false" visible="false"/>

        <!-- Username -->
        <VBox spacing="4">
            <Label text="Username" style="-fx-text-fill:#8b949e; -fx-font-size:12px;"/>
            <TextField fx:id="usernameField" promptText="Enter username"
                       style="-fx-background-color:#21262d; -fx-text-fill:#e6edf3;
                              -fx-border-color:#30363d; -fx-border-radius:6;
                              -fx-background-radius:6; -fx-padding:8 12;
                              -fx-font-size:14px; -fx-pref-height:38;"/>
        </VBox>

        <VBox spacing="0"><padding><Insets top="12"/></padding></VBox>

        <!-- Password -->
        <VBox spacing="4">
            <Label text="Password" style="-fx-text-fill:#8b949e; -fx-font-size:12px;"/>
            <PasswordField fx:id="passwordField" promptText="Enter password"
                           style="-fx-background-color:#21262d; -fx-text-fill:#e6edf3;
                                  -fx-border-color:#30363d; -fx-border-radius:6;
                                  -fx-background-radius:6; -fx-padding:8 12;
                                  -fx-font-size:14px; -fx-pref-height:38;"
                           onAction="#onLogin"/>
        </VBox>

        <VBox spacing="0"><padding><Insets top="20"/></padding></VBox>

        <!-- Login button -->
        <Button fx:id="loginBtn" text="Sign In" onAction="#onLogin"
                maxWidth="Infinity" prefHeight="40"
                style="-fx-background-color:#238636; -fx-text-fill:white;
                       -fx-font-size:14px; -fx-font-weight:bold;
                       -fx-background-radius:6; -fx-cursor:hand;"/>

        <VBox spacing="0"><padding><Insets top="12"/></padding></VBox>

        <!-- Separator -->
        <HBox alignment="CENTER" spacing="8">
            <Separator HBox.hgrow="ALWAYS"/>
            <Label text="or" style="-fx-text-fill:#8b949e; -fx-font-size:12px;"/>
            <Separator HBox.hgrow="ALWAYS"/>
        </HBox>

        <VBox spacing="0"><padding><Insets top="12"/></padding></VBox>

        <!-- Register link -->
        <Button text="Create new account" onAction="#onShowRegister"
                maxWidth="Infinity" prefHeight="38"
                style="-fx-background-color:transparent; -fx-text-fill:#388bfd;
                       -fx-font-size:13px; -fx-border-color:#30363d;
                       -fx-border-radius:6; -fx-background-radius:6; -fx-cursor:hand;"/>

        <VBox spacing="0"><padding><Insets top="20"/></padding></VBox>

        <!-- Default credentials hint -->
        <Label text="Default admin: admin / admin123"
               style="-fx-text-fill:#8b949e; -fx-font-size:11px;" alignment="CENTER"/>

    </VBox>
</StackPane>
