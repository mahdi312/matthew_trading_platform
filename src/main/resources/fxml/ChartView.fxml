<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.mst.matt.tradingplatformapp.controller.ChartController"
      styleClass="scene-root" spacing="0">

    <!-- Top Toolbar (horizontal scroll so labels are never clipped to "...") -->
    <ScrollPane fitToHeight="true" hbarPolicy="AS_NEEDED" vbarPolicy="NEVER"
                style="-fx-background-color:#1c2128; -fx-background:#1c2128;">
        <HBox styleClass="card" alignment="CENTER_LEFT" spacing="10"
              style="-fx-background-radius:0; -fx-border-radius:0; -fx-border-width:0 0 1 0;">
            <padding>
                <Insets top="10" right="12" bottom="10" left="12"/>
            </padding>

            <!-- Symbol -->
            <Label text="Symbol:" styleClass="label-subtitle"/>
            <ComboBox fx:id="symbolCombo" prefWidth="130" promptText="Pick symbol"/>
            <TextField fx:id="symbolInput" promptText="Or type symbol"
                       prefWidth="140" onAction="#onLoadChart"/>
            <Button text="Load" styleClass="btn-primary" onAction="#onLoadChart"
                    style="-fx-min-width:64;"/>

            <Separator orientation="VERTICAL"/>

            <!-- Timeframes -->
            <Label text="Timeframe:" styleClass="label-subtitle"/>
            <ToggleButton fx:id="tf1m" text="1m" styleClass="btn-secondary chart-tf-btn" onAction="#onTimeframe"/>
            <ToggleButton fx:id="tf5m" text="5m" styleClass="btn-secondary chart-tf-btn" onAction="#onTimeframe"/>
            <ToggleButton fx:id="tf15m" text="15m" styleClass="btn-secondary chart-tf-btn" onAction="#onTimeframe"/>
            <ToggleButton fx:id="tf1h" text="1h" styleClass="btn-blue chart-tf-btn" onAction="#onTimeframe"/>
            <ToggleButton fx:id="tf4h" text="4h" styleClass="btn-secondary chart-tf-btn" onAction="#onTimeframe"/>
            <ToggleButton fx:id="tf1d" text="1D" styleClass="btn-secondary chart-tf-btn" onAction="#onTimeframe"/>
            <ToggleButton fx:id="tf1w" text="1W" styleClass="btn-secondary chart-tf-btn" onAction="#onTimeframe"/>

            <Separator orientation="VERTICAL"/>

            <!-- Bars -->
            <Label text="Bars:" styleClass="label-subtitle"/>
            <ComboBox fx:id="barsCombo" prefWidth="85"/>

            <Separator orientation="VERTICAL"/>

            <!-- Overlays -->
            <Label text="Overlays:" styleClass="label-subtitle"/>
            <CheckBox fx:id="chkEma" text="EMA" selected="true" onAction="#onToggleEma"/>
            <CheckBox fx:id="chkBollinger" text="BB" selected="true" onAction="#onToggleBollinger"/>
            <CheckBox fx:id="chkIchimoku" text="Ichimoku" selected="true" onAction="#onToggleIchimoku"/>
            <CheckBox fx:id="chkSR" text="S/R" selected="true" onAction="#onToggleSR"/>
            <CheckBox fx:id="chkVolume" text="Vol" selected="true" onAction="#onToggleVolume"/>
            <CheckBox fx:id="chkMacd" text="MACD" selected="true" onAction="#onToggleMacd"/>
            <CheckBox fx:id="chkRsi" text="RSI" selected="true" onAction="#onToggleRsi"/>

            <Separator orientation="VERTICAL"/>

            <Label text="Source:" styleClass="label-subtitle"/>
            <ComboBox fx:id="chartProviderCombo" prefWidth="170" onAction="#onChartProviderChanged"/>
            <Label fx:id="dataSourceLabel" text="—" styleClass="label-muted"/>

            <Button text="Refresh" styleClass="btn-secondary" onAction="#onRefresh"
                    style="-fx-min-width:72;"/>
            <Button text="Analyze" styleClass="btn-primary" onAction="#onAnalyze"
                    style="-fx-min-width:72;"/>
        </HBox>
    </ScrollPane>

    <!-- Signal Bar -->
    <HBox fx:id="signalBar" alignment="CENTER_LEFT" spacing="12" visible="false"
          style="-fx-background-color:#161b22; -fx-border-color:#30363d; -fx-border-width:0 0 1 0;">
        <padding>
            <Insets top="8" right="16" bottom="8" left="16"/>
        </padding>
        <Label fx:id="signalLabel" text="" style="-fx-font-weight:bold; -fx-font-size:14px;"/>
        <Label fx:id="confidenceLabel" text="" styleClass="label-subtitle"/>
        <Separator orientation="VERTICAL"/>
        <Label text="Best Buy:" styleClass="label-muted"/>
        <Label fx:id="bestBuyLabel" text="—" style="-fx-text-fill:#3fb950; -fx-font-weight:bold;"/>
        <Label text="Best Sell:" styleClass="label-muted"/>
        <Label fx:id="bestSellLabel" text="—" style="-fx-text-fill:#f85149; -fx-font-weight:bold;"/>
        <Separator orientation="VERTICAL"/>
        <Label fx:id="bullBearLabel" text="" styleClass="label-subtitle"/>
        <Pane HBox.hgrow="ALWAYS"/>
        <Label fx:id="currentPriceChartLabel" text=""
               style="-fx-font-size:18px; -fx-font-weight:bold; -fx-text-fill:#e6edf3;"/>
    </HBox>

    <!-- Chart Area -->
    <Pane fx:id="chartPane" VBox.vgrow="ALWAYS" style="-fx-background-color:#0d1117;"/>

</VBox>
