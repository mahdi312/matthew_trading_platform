<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<!-- BorderPane keeps the symbol/toolbar row pinned at the top; chart fills center only. -->
<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:id="chartRoot"
            fx:controller="com.mst.matt.tradingplatformapp.controller.ChartController"
            styleClass="scene-root"
            maxWidth="Infinity" maxHeight="Infinity"
            minWidth="0" minHeight="0">

    <top>
        <VBox spacing="0">
            <!-- ── Symbol / Toolbar row ──────────────────────────────────────
                 The ScrollPane provides horizontal scroll on narrow windows so
                 controls never overflow or overlap.  fitToWidth="false" keeps
                 the inner HBox at its natural content width so no phantom empty
                 space appears on the right side when TF buttons are few.
                 The HBox itself uses a combination of fixed min-widths and a
                 single HBox.hgrow="ALWAYS" Pane spacer to push action buttons
                 to the right edge without leaving gaps on the left side.
            ─────────────────────────────────────────────────────────────── -->
            <ScrollPane fx:id="chartToolbarScroll"
                        fitToWidth="true" fitToHeight="true"
                        hbarPolicy="AS_NEEDED" vbarPolicy="NEVER"
                        minHeight="44" prefHeight="44" maxHeight="44"
                        style="-fx-background-color:#1c2128; -fx-background:#1c2128;
                               -fx-border-color:#30363d; -fx-border-width:0 0 1 0;">
                <!-- All controls in a single horizontal bar.
                     - spacing="4" keeps items snug but readable.
                     - -fx-padding: 4 top/bottom so the bar height is predictable.
                     - minWidth: -Infinity lets JavaFX compute the real minimum so
                       the ScrollPane horizontal scroll kicks in correctly. -->
                <HBox alignment="CENTER_LEFT" spacing="4"
                      minWidth="-Infinity"
                      style="-fx-background-color:#1c2128; -fx-padding:4 8 4 8;">

                    <!-- ── Symbol group ── -->
                    <Label text="Sym" styleClass="label-muted"
                           style="-fx-font-size:10px; -fx-text-fill:#6e7681; -fx-min-width:26;"/>
                    <ComboBox fx:id="symbolCombo"
                              prefWidth="108" minWidth="80" maxWidth="130"
                              style="-fx-font-size:12px;"
                              promptText="Symbol"/>
                    <TextField fx:id="symbolInput"
                               promptText="Type symbol…"
                               prefWidth="108" minWidth="80" maxWidth="130"
                               style="-fx-font-size:12px; -fx-padding:3 8;"
                               onAction="#onLoadChart"/>
                    <Button text="▶" styleClass="btn-primary"
                            onAction="#onLoadChart"
                            style="-fx-font-size:12px; -fx-padding:3 10; -fx-min-width:34; -fx-font-weight:bold;">
                        <tooltip><Tooltip text="Load chart (Enter)"/></tooltip>
                    </Button>

                    <Separator orientation="VERTICAL" style="-fx-pref-height:24; -fx-opacity:0.4;"/>

                    <!-- ── Timeframe group ── -->
                    <Label text="TF" styleClass="label-muted"
                           style="-fx-font-size:10px; -fx-text-fill:#6e7681; -fx-min-width:18;"/>
                    <!-- Hidden FXML TF buttons kept for ToggleGroup binding only -->
                    <ToggleButton fx:id="tf1m"  text="1m"   styleClass="btn-secondary chart-tf-btn" onAction="#onTimeframe" visible="false" managed="false"/>
                    <ToggleButton fx:id="tf3m"  text="3m"   styleClass="btn-secondary chart-tf-btn" onAction="#onTimeframe" visible="false" managed="false"/>
                    <ToggleButton fx:id="tf5m"  text="5m"   styleClass="btn-secondary chart-tf-btn" onAction="#onTimeframe" visible="false" managed="false"/>
                    <ToggleButton fx:id="tf15m" text="15m"  styleClass="btn-secondary chart-tf-btn" onAction="#onTimeframe" visible="false" managed="false"/>
                    <ToggleButton fx:id="tf30m" text="30m"  styleClass="btn-secondary chart-tf-btn" onAction="#onTimeframe" visible="false" managed="false"/>
                    <ToggleButton fx:id="tf1h"  text="1h"   styleClass="btn-blue     chart-tf-btn" onAction="#onTimeframe" visible="false" managed="false"/>
                    <ToggleButton fx:id="tf2h"  text="2h"   styleClass="btn-secondary chart-tf-btn" onAction="#onTimeframe" visible="false" managed="false"/>
                    <ToggleButton fx:id="tf4h"  text="4h"   styleClass="btn-secondary chart-tf-btn" onAction="#onTimeframe" visible="false" managed="false"/>
                    <ToggleButton fx:id="tf6h"  text="6h"   styleClass="btn-secondary chart-tf-btn" onAction="#onTimeframe" visible="false" managed="false"/>
                    <ToggleButton fx:id="tf8h"  text="8h"   styleClass="btn-secondary chart-tf-btn" onAction="#onTimeframe" visible="false" managed="false"/>
                    <ToggleButton fx:id="tf12h" text="12h"  styleClass="btn-secondary chart-tf-btn" onAction="#onTimeframe" visible="false" managed="false"/>
                    <ToggleButton fx:id="tf1d"  text="1D"   styleClass="btn-secondary chart-tf-btn" onAction="#onTimeframe" visible="false" managed="false"/>
                    <ToggleButton fx:id="tf3d"  text="3D"   styleClass="btn-secondary chart-tf-btn" onAction="#onTimeframe" visible="false" managed="false"/>
                    <ToggleButton fx:id="tf1w"  text="1W"   styleClass="btn-secondary chart-tf-btn" onAction="#onTimeframe" visible="false" managed="false"/>
                    <ToggleButton fx:id="tf1mo" text="1Mo"  styleClass="btn-secondary chart-tf-btn" onAction="#onTimeframe" visible="false" managed="false"/>
                    <!-- Favorites bar — dynamically built by ChartController; shrinks/grows
                         with its children. No fixed maxWidth so no phantom trailing gap. -->
                    <HBox fx:id="favTfBar" spacing="3" alignment="CENTER_LEFT"
                          minWidth="0" maxWidth="Infinity"/>
                    <!-- All-timeframes dropdown (star button) -->
                    <Button fx:id="tfDropdownBtn" text="☆" styleClass="btn-secondary"
                            onAction="#onOpenTfDropdown"
                            style="-fx-font-size:12px; -fx-padding:3 7; -fx-min-width:26;">
                        <tooltip><Tooltip text="All timeframes — add/remove from favorites"/></tooltip>
                    </Button>

                    <Separator orientation="VERTICAL" style="-fx-pref-height:24; -fx-opacity:0.4;"/>

                    <!-- ── Bars count ── -->
                    <Label text="Bars" styleClass="label-muted"
                           style="-fx-font-size:10px; -fx-text-fill:#6e7681; -fx-min-width:28;"/>
                    <ComboBox fx:id="barsCombo" prefWidth="76" minWidth="60" maxWidth="90"
                              style="-fx-font-size:11px;"/>

                    <Separator orientation="VERTICAL" style="-fx-pref-height:24; -fx-opacity:0.4;"/>

                    <!-- ── Indicators button ── -->
                    <Button fx:id="indicatorPickerBtn" text="📊 Ind"
                            styleClass="btn-secondary"
                            onAction="#onOpenIndicatorPicker"
                            style="-fx-font-size:11px; -fx-padding:3 8; -fx-min-width:58;">
                        <tooltip><Tooltip text="Add/remove indicators"/></tooltip>
                    </Button>

                    <!-- Analysis-mode extra toolbar (shown only in analysis mode) -->
                    <HBox fx:id="analysisToolbar" spacing="4" alignment="CENTER_LEFT"
                          visible="false" managed="false"/>

                    <!-- Notification bell -->
                    <Button fx:id="chartNotifyBellBtn" text="🔔" styleClass="btn-secondary"
                            onAction="#onToggleChartNotifications"
                            style="-fx-font-size:11px; -fx-padding:3 6; -fx-min-width:28;">
                        <tooltip><Tooltip text="Toggle chart notifications"/></tooltip>
                    </Button>

                    <Separator orientation="VERTICAL" style="-fx-pref-height:24; -fx-opacity:0.4;"/>

                    <!-- ── Data source ── -->
                    <Label text="Src" styleClass="label-muted"
                           style="-fx-font-size:10px; -fx-text-fill:#6e7681; -fx-min-width:24;"/>
                    <ComboBox fx:id="chartProviderCombo"
                              prefWidth="120" minWidth="90" maxWidth="150"
                              style="-fx-font-size:11px;"
                              onAction="#onChartProviderChanged"/>
                    <Label fx:id="dataSourceLabel" text="—" styleClass="label-muted"
                           style="-fx-font-size:10px; -fx-max-width:70; -fx-min-width:0;"/>

                    <!-- Flexible spacer: pushes action group to the far right.
                         HBox.hgrow="ALWAYS" ensures it expands first, so the TF
                         bar and source label don't get squished at medium widths. -->
                    <Pane HBox.hgrow="ALWAYS" minWidth="4"/>

                    <!-- ── Action buttons (right-aligned) ── -->
                    <Button text="↺" styleClass="btn-secondary"
                            onAction="#onRefresh"
                            style="-fx-font-size:13px; -fx-padding:3 8; -fx-min-width:30;">
                        <tooltip><Tooltip text="Refresh chart data"/></tooltip>
                    </Button>
                    <Button fx:id="analyzeBtn" text="⚡ Analyze" styleClass="btn-primary"
                            onAction="#onAnalyze"
                            style="-fx-font-size:11px; -fx-padding:3 9; -fx-min-width:74;"
                            visible="false" managed="false">
                        <tooltip><Tooltip text="Run technical analysis"/></tooltip>
                    </Button>

                    <Separator orientation="VERTICAL" style="-fx-pref-height:24; -fx-opacity:0.4;"/>

                    <!-- Fullscreen toggle (F11) -->
                    <Button fx:id="fullscreenBtn" text="⛶" styleClass="btn-secondary"
                            onAction="#onToggleFullscreen"
                            style="-fx-min-width:30; -fx-padding:3 7; -fx-font-size:14px;">
                        <tooltip><Tooltip text="Toggle fullscreen (F11)"/></tooltip>
                    </Button>
                </HBox>
            </ScrollPane>

            <!-- Signal bar (analysis mode only) -->
            <HBox fx:id="signalBar" alignment="CENTER_LEFT" spacing="12"
                  visible="false" managed="false"
                  style="-fx-background-color:#161b22; -fx-border-color:#30363d;
                         -fx-border-width:0 0 1 0; -fx-padding:7 16 7 16;">
                <Label fx:id="signalLabel" text="" style="-fx-font-weight:bold; -fx-font-size:14px;"/>
                <Label fx:id="confidenceLabel" text="" styleClass="label-subtitle"/>
                <Separator orientation="VERTICAL"/>
                <Label text="Best Buy:" styleClass="label-muted"/>
                <Label fx:id="bestBuyLabel" text="—" style="-fx-text-fill:#3fb950; -fx-font-weight:bold;"/>
                <Label text="Best Sell:" styleClass="label-muted"/>
                <Label fx:id="bestSellLabel" text="—" style="-fx-text-fill:#f85149; -fx-font-weight:bold;"/>
                <Separator orientation="VERTICAL"/>
                <Label text="Sentiment:" styleClass="label-muted"/>
                <HBox fx:id="sentimentBox" spacing="6" alignment="CENTER_LEFT">
                    <Label fx:id="bullCircle"    text="0" styleClass="sentiment-circle-buying"/>
                    <Label fx:id="neutralCircle" text="0" styleClass="sentiment-circle-neutral"/>
                    <Label fx:id="bearCircle"    text="0" styleClass="sentiment-circle-selling"/>
                </HBox>
                <Label fx:id="bullBearLabel" text="" styleClass="label-subtitle"
                       visible="false" managed="false"/>
                <Pane HBox.hgrow="ALWAYS"/>
                <Label fx:id="currentPriceChartLabel" text=""
                       style="-fx-font-size:18px; -fx-font-weight:bold; -fx-text-fill:#e6edf3;"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <StackPane fx:id="chartStack" minWidth="0" minHeight="0"
                   maxWidth="Infinity" maxHeight="Infinity">
            <Pane fx:id="chartPane" style="-fx-background-color:#0d1117;"
                  maxWidth="Infinity" maxHeight="Infinity"/>
            <!-- Toast notifications (top-right, max 3) -->
            <VBox fx:id="notificationOverlay" alignment="TOP_RIGHT"
                  visible="false" managed="false"
                  mouseTransparent="false"
                  StackPane.alignment="TOP_RIGHT"/>
        </StackPane>
    </center>

</BorderPane>
